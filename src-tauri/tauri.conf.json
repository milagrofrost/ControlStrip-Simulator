{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ControlStrip Simulator",
  "version": "0.1.0",
  "identifier": "com.milagrofrost.controlstrip",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ControlStrip Simulator",
        "width": 600,
        "height": 200,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"]
  }
}
